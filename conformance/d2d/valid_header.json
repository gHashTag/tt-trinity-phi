      "payload_note": "First four Lucas L2..L5 values; slaves verify against lucas_rom",
      "crc8": "0xAB",
      "crc_valid": true,
      "eof_marker": "ui_in[0]=0 for 2 cycles"
    }
  ],
  "wire_trace": [
