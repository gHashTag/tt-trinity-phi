{
  "$schema": "tt-trinity-phi/d2d-conformance-vector/1.0",
  "scenario_id": "D2D-VEC-4",
  "scenario_name": "Slave non-response — Phi exhausts retries and RESYNCs",
  "claims_matrix_rows": ["VC-D2D-3"],
  "protocol_version": "1.0",
