    { "cycle": 10, "phase": "IDLE",       "wire_c_ack": "high" }
  ],
  "expected_state_transitions": ["IDLE", "LOAD_PHASE", "EOF", "SYNC_BURST", "ACK_TIMEOUT", "IDLE"],
