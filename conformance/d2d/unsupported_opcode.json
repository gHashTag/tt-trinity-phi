    { "cycle": 7,  "phase": "SYNC_BURST", "wire_b_sync_strobe": 1, "wire_c_ack": "high" },
    { "cycle": 8,  "phase": "SYNC_BURST", "wire_b_sync_strobe": 1, "wire_c_ack": "high", "note": "No ACK from any slave" },
