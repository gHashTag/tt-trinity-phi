test "gf16_hypot_pythagorean_triple" {
    const a = gf16_encode_f32(3.0);
    const b = gf16_encode_f32(4.0);
    const result = gf16_hypot(a, b);
    const decoded = gf16_decode_to_f32(result);
    try std.testing.expectApproxEqAbs(5.0, decoded, 0.1); // sqrt(9 + 16) = 5
}

