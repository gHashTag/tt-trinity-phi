test "gf16_comparison_consistency" {
    // Verify: lt, le, gt, ge, eq, ne are mutually consistent
    const a = gf16_encode_f32(2.0);
    const b = gf16_encode_f32(3.0);

    // a < b implies a <= b and !a > b and !a >= b
    try std.testing.expect(gf16_lt(a, b));
    try std.testing.expect(gf16_le(a, b));
    try std.testing.expect(!gf16_gt(a, b));
    try std.testing.expect(!gf16_ge(a, b));
}

