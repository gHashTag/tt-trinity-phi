    const decoded = gf16_decode_to_f32(result);
    try std.testing.expectApproxEqAbs(-1.0, decoded, 0.1); // -10 % 3 = -1 (sign follows dividend)
}

test "gf16_fmod_fractional" {
    const a = gf16_encode_f32(5.5);
    const b = gf16_encode_f32(2.0);
    const result = gf16_fmod(a, b);
    const decoded = gf16_decode_to_f32(result);
    try std.testing.expectApproxEqAbs(1.5, decoded, 0.1); // 5.5 % 2 = 1.5
}

