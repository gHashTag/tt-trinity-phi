    given value: Int4 = 5
    try std.testing.expect(result = int4_to_i8(value));
    try std.testing.expect(result == value);
}

test "int4_to_i16_sign_extend" {
    given value: Int4 = -1
    try std.testing.expect(result = int4_to_i16(value));
    try std.testing.expect(result == -1);
}

test "int4_to_i32_sign_extend" {
    given value: Int4 = -1
    try std.testing.expect(result = int4_to_i32(value));
    try std.testing.expect(result == -1);
}

test "int4_to_f32_positive" {
    given value: Int4 = 5
    try std.testing.expect(result = int4_to_f32(value));
    try std.testing.expect(abs(result - 5.0) < 0.001);
}

