test "int4_mul_overflow" {
    given a: Int4 = 4
    try std.testing.expect(b: Int4 = 4);
    try std.testing.expect(result = int4_mul(a, b));
    try std.testing.expect(result == MAX  // 4 * 4 = 16 -> 7);
}

