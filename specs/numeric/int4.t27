    given value: Int4 = -3
    try std.testing.expect(result = int4_to_f32(value));
    try std.testing.expect(abs(result + 3.0) < 0.001);
}

test "int4_add_simple" {
    given a: Int4 = 3
    try std.testing.expect(b: Int4 = 4);
    try std.testing.expect(result = int4_add(a, b));
    try std.testing.expect(result == MAX  // 3 + 4 = 7 = MAX);
}

test "int4_add_overflow" {
    given a: Int4 = 5
    try std.testing.expect(b: Int4 = 5);
    try std.testing.expect(result = int4_add(a, b));
    try std.testing.expect(result == MAX  // 5 + 5 = 10 -> 7);
}

test "int4_add_underflow" {
    given a: Int4 = -5
    try std.testing.expect(b: Int4 = -5);
    try std.testing.expect(result = int4_add(a, b));
    try std.testing.expect(result == MIN  // -5 + -5 = -10 -> -8);
}

